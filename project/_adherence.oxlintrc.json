{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data-display/**",
              "components/forms/**",
              "components/navigation/**",
              "data.js",
              "design_handoff_service_hub/changed_files/**",
              "design_handoff_service_hub/new_files/**",
              "ds_icons.js",
              "ui_kits/service-hub/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Arimo|IBM Plex Sans|IBM Plex Sans Arabic|IBM Plex Mono|Material Symbols Outlined))/i]",
        "message": "Font not provided by the design system. Available: Arimo, IBM Plex Sans, IBM Plex Sans Arabic, IBM Plex Mono, Material Symbols Outlined."
      },
      {
        "selector": "JSXOpeningElement[name.name='Crumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|onClick|key|ref|className|style|children)$/]",
        "message": "<Crumb> doesn't accept that prop. Declared props: label, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconEnd|busy|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconEnd, busy, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|interactive|glass|brandRim|as|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: size, interactive, glass, brandRim, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<Card> size must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|section|icon|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, section, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='section'] > Literal[value!=/^(?:CS|CB|CT|CA)$/]",
        "message": "<Chip> section must be one of 'CS' | 'CB' | 'CT' | 'CA'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|hint|error|htmlFor|children|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, required, hint, error, htmlFor, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|filled|bold|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, filled, bold."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Icon> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|bare|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, bare, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:invalid|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: invalid."
      },
      {
        "selector": "JSXOpeningElement[name.name='SaveBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<SaveBadge> doesn't accept that prop. Declared props: status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SaveBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:idle|saving|saved|error)$/]",
        "message": "<SaveBadge> status must be one of 'idle' | 'saving' | 'saved' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:hero|icon|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: hero, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:section|children|key|ref|className|style|children)$/]",
        "message": "<SectionBadge> doesn't accept that prop. Declared props: section, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionBadge'] > JSXAttribute[name.name='section'] > Literal[value!=/^(?:CS|CB|CT|CA)$/]",
        "message": "<SectionBadge> section must be one of 'CS' | 'CB' | 'CT' | 'CA'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SLATag'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|active|children|key|ref|className|style|children)$/]",
        "message": "<SLATag> doesn't accept that prop. Declared props: level, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SLATag'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:standard|urgent|vip)$/]",
        "message": "<SLATag> level must be one of 'standard' | 'urgent' | 'vip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|badge|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: key, label, icon, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|success|warn|err|info|crimson|gold)$/]",
        "message": "<Tag> tone must be one of 'default' | 'success' | 'warn' | 'err' | 'info' | 'crimson' | 'gold'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
